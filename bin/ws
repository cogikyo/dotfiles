#!/usr/bin/env bash
set -euo pipefail

ws="$1"
current=$(hyprctl activeworkspace -j | jq '.id')

# Spatial layout:
#        1
#     2  3  4
#        5
anim="slide"
if [[ "$ws" == "1" || "$current" == "1" ]]; then
    anim="slidevert"
elif [[ "$ws" == "5" || "$current" == "5" ]]; then
    anim="slidevert"
fi

hyprctl keyword animation "workspaces, 1, 0.5, default, $anim"
hyprctl dispatch workspace "$ws"
change-bg "kill"
hyprctl keyword animation "workspaces, 1, 0.5, default, slide"

