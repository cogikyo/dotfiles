#!/usr/bin/env bash
set -euo pipefail

root=$(git rev-parse --show-toplevel) || { echo "Not in a git repo."; exit 1; }
diff=$(git -C "$root" diff --cached)

if [[ -z "$diff" ]]; then
	echo "No staged changes to commit."
	exit 1
fi

msg=$(echo "$diff" | claude -p --model sonnet \
	"Generate a conventional commit message for this staged diff.
Output ONLY the commit message, nothing else.
First line: type(scope): short summary (under 72 chars).
If needed, add a blank line then bullet-point details.
Types: feat, fix, refactor, chore, update, style, docs, test, perf.")

if [[ -z "$msg" ]]; then
	echo "Failed to generate commit message."
	exit 1
fi

echo -e "\n$msg\n"
git commit -m "$(cat <<EOF
$msg
EOF
)"
