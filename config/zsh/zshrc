# ╭──────────────────────────────────────────────────────────────────────────╮
# │ Prompt & Init                                                            │
# ╰──────────────────────────────────────────────────────────────────────────╯

eval "$(starship init zsh)"
eval "$(zoxide init zsh)"

function command_not_found_handler {
    return 127
}

# ╭──────────────────────────────────────────────────────────────────────────╮
# │ History                                                                  │
# ╰──────────────────────────────────────────────────────────────────────────╯

HISTFILE=~/.histfile
HISTSIZE=10000
SAVEHIST=10000

setopt EXTENDED_HISTORY       # Store timestamps and command durations.
setopt SHARE_HISTORY          # Share history across active shell sessions.
setopt HIST_IGNORE_SPACE      # Do not save commands that start with a space.
setopt HIST_IGNORE_ALL_DUPS   # Remove older duplicates when adding commands.
setopt HIST_FIND_NO_DUPS      # Skip duplicates during history searches.
setopt HIST_EXPIRE_DUPS_FIRST # Prefer pruning duplicates when history is full.
setopt HIST_SAVE_NO_DUPS      # Do not write duplicate entries to the history file.
setopt HIST_REDUCE_BLANKS     # Collapse extra whitespace before saving commands.
setopt HIST_VERIFY            # Show history-expanded commands before running them.
setopt HIST_NO_STORE          # Do not store the `history` command itself.

setopt AUTO_CD                # Change directories by typing the path directly.
setopt AUTO_PUSHD             # Add previous directories to the stack on `cd`.
setopt PUSHD_IGNORE_DUPS      # Keep only one stack entry per directory.
setopt PUSHD_SILENT           # Do not print the stack after directory changes.
setopt EXTENDED_GLOB          # Enable richer glob patterns like negation and grouping.
setopt GLOB_DOTS              # Include dotfiles in glob matches.
setopt NUMERIC_GLOB_SORT      # Sort numbers naturally: file2 before file10.
setopt INTERACTIVE_COMMENTS   # Allow comments in interactive commands.

# ╭──────────────────────────────────────────────────────────────────────────╮
# │ Hooks                                                                    │
# ╰──────────────────────────────────────────────────────────────────────────╯

chpwd() {
    echo
    lsd
}

autoload -Uz add-zsh-hook

command_output_spacer() {
    print
}
add-zsh-hook preexec command_output_spacer

# ╭──────────────────────────────────────────────────────────────────────────╮
# │ Aliases                                                                  │
# ╰──────────────────────────────────────────────────────────────────────────╯

alias install='~/dotfiles/install.sh'
alias build='~/dotfiles/build.sh'

alias niol='clear && source ~/.zshrc'
alias ls='echo; lsd'
alias n='nvim'
function c() {
    opencode attach http://127.0.0.1:4096 --dir "$PWD" "$@"
}
alias cr='systemctl --user restart opencode && echo "opencode server restarted"'
alias cl='claude --model claude-sonnet-4-6 --effort high'
alias cc='claude --model claude-opus-4-6 --effort high'
alias ch='claude --model claude-opus-4-7 --effort xhigh'
alias zz='cd ~'
alias l='z ~/LeadPier'
alias s='cd "$(xplr --print-pwd-as-result)"'
alias rh='git reset --soft HEAD~1'
alias d='cd ~/dotfiles'
alias D='cd ~/downloads'
alias p='pier'
alias pv='pier view'
alias pw='pier watch'
alias pu='pier update'
alias zp='cd ~/LeadPier/backend/services/partner'
alias lg='lazygit'
alias ld='lazydocker'
alias uvpn='hyprd vpn Trend up'
alias dvpn='hyprd vpn Trend down'

alias fe='cd ~/LeadPier/frontend'
alias bk='cd ~/LeadPier/backend'

alias oc='ouch compress'
alias od='ouch decompress'
alias ol='ouch list --tree'
alias man='man --pager=$PAGER'
alias explicit='sudo pacman -D --asexplicit'

function etree () {
    echo
    if [[ -z $1 ]]; then
        L=2
    else
        L=$1
    fi
    erd -L "$L" --suppress-size --threads 16 --dir-order last --sort rname --color force --layout inverted | head -n -2
}

alias sshadd='ssh-add ~/.ssh/cogikyo ~/.ssh/trend ~/.ssh/cullyn'
alias ew='ewwd open'
alias ews='eww inspector & disown && exit'
alias el='eww logs'

# ╭──────────────────────────────────────────────────────────────────────────╮
# │ Plugins                                                                  │
# ╰──────────────────────────────────────────────────────────────────────────╯

if [[ ! -f ${ZDOTDIR:-${HOME}}/.zcomet/bin/zcomet.zsh ]]; then
    command git clone https://github.com/agkozak/zcomet.git ${ZDOTDIR:-${HOME}}/.zcomet/bin
fi
source ${ZDOTDIR:-${HOME}}/.zcomet/bin/zcomet.zsh

ZSH_AUTOSUGGEST_BUFFER_MAX_SIZE=20
ZSH_AUTOSUGGEST_STRATEGY=(history completion)

# Order matters -- syntax highlighting must load last.
zcomet load zsh-users/zsh-completions
zcomet load zsh-users/zsh-autosuggestions
zcomet load Aloxaf/fzf-tab
zcomet load zsh-users/zsh-syntax-highlighting

zstyle ':completion:*' matcher-list 'm:{a-zA-Z}={A-Za-z}'

autoload -U compinit; compinit

# ╭──────────────────────────────────────────────────────────────────────────╮
# │ Key Bindings                                                             │
# ╰──────────────────────────────────────────────────────────────────────────╯

bindkey -v
export KEYTIMEOUT=01
bindkey '^[[H'     vi-beginning-of-line
bindkey '^[[F'     vi-end-of-line
bindkey '^[[3~'    delete-char
bindkey '^[[1;5C'  forward-word   # C-Right
bindkey '^[[1;5D'  backward-word  # C-Left
bindkey '^[[1;5A'  history-incremental-search-backward # C-Up
bindkey '^[[1;5B'  history-incremental-search-forward  # C-Down

eval "$(atuin init zsh --disable-up-arrow)"

source $HOME/.config/zsh/vagari-highlights.zsh
