[user]
	name = cullyn
	email = cullyn.newman@gmail.com
	signingkey = ~/.ssh/cullyn.pub
[core]
	editor = nvim
	ignorecase = false
[gpg]
	format = ssh
[gpg "ssh"]
	allowedSignersFile = ~/.config/git/allowed_signers
[commit]
	gpgsign = true
[pull]
	rebase = true
[init]
	defaultBranch = master
[url "git@git.linecode.dev:"]
	insteadOf = https://git.linecode.dev/
[includeIf "gitdir:/Users/"]
	path = ~/.config/git/config-mac ; macOS key paths differ
[includeIf "hasconfig:remote.*.url:git@git.linecode.dev:*/**"]
	path = ~/.config/git/config-work
[includeIf "hasconfig:remote.*.url:git@git.trendcapital.io:*/**"]
	path = ~/.config/git/config-work
