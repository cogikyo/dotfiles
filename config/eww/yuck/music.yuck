;; ============================================================================
;; player

(defwindow player
  :monitor 0 :stacking "bottom" :exclusive false :focusable false
  :geometry (geometry :anchor "top left" :y "-3px")
  (player)
)

(defvar player "/home/cullyn/.config/eww/art/player.png")

(defwidget player []
  (eventbox
    :onmiddleclick "${browser} https://www.google.com/search?q='${pctl.artist}' & disown"
    :onrightclick "hyprctl dispatch workspace 1 & disown"
    :tooltip "  ا‚ search artist آ· َ°³¾ music workspace  "
    (box
      :class "playerbox"
      :style "margin-left: -5px; background-image: url('${pctl.has_canvas ? pctl.canvas_frame : (pctl.playing ? pctl.art_path : playerctl-img)}'); ${pctl.has_canvas ? 'transition: none;' : ''}"
    )
  )
)

;; ----------------------------------------------------------------------------
;; music

(defwindow music
  :monitor 0 :stacking "bottom" :exclusive false :focusable false
  :geometry (geometry :anchor "top left" :x "20px")
  (box
    :halign "start" :space-evenly false :spacing 0
    :class "tr-m"
    (music) (audio)
  )
)

(deflisten pctl
  :initial '{ "status":"Paused", "playing":false, "volume":"1.0", "volume_percent":100, "artist":"", "artist_short":"", "album":"", "album_short":"", "title":"", "title_short":"", "single_track":false, "progress":0, "art_path":"/tmp/eww/album_art.png", "has_canvas":false, "canvas_frame":"" }'
  'ewwd subscribe music | jq --unbuffered -c ".data"'
)

(defvar playerctl-img `/home/cullyn/.config/eww/art/player.png`)

(defwidget music []
  (eventbox
    :onhover "eww update hover=music"
    :onhoverlost "eww update hover=''"
    (box
      :class "music-info ${hover == "music" ? "music-info-hover" : ""}"
      :style "
        padding-left: ${hover == "music" ? "1" : "0.8"}em;
        padding-right: ${hover == "music" ? "1" : "0.6"}em;
        transition: padding 0.25s ease-out;
      "
      :space-evenly false
      :spacing 16
      (slide-n-fade :direction "left" :bool {hover == "music"}
        (eventbox
          :class "tr-a music-progress-circle-icon-${pctl.playing ? "playing" : "paused" }"
          :cursor "pointer"
          :onclick "ewwd action music previous"
          :tooltip "  َ°³½ previous track  "
          (label :text "َ°’®")
        )
      )
      (music-progress)
      (slide-n-fade :direction "right" :bool {hover == "music"}
        (eventbox
          :class "tr-a music-progress-circle-icon-${pctl.playing ? "playing" : "paused" }"
          :cursor "pointer"
          :onclick "ewwd action music next"
          :tooltip "  َ°³½ next track  "
          (label :text "َ°’­")
        )
      )
      (label
        :class "tr-c music-${pctl.playing ? "artist" : "inactive" }"
        :text "َ° ƒ ${pctl.artist_short}"
        :tooltip " َ° ƒ ${pctl.artist} "
        :style "margin-left: ${hover == "music" ? "-2" : "-12"}px;"
      )
      (label
        :class "tr-c music-${pctl.playing ? "album" : "inactive" }"
        :text "َ°€¥ ${pctl.album_short}"
        :tooltip " َ°€¥ ${pctl.album} "
        :style "${pctl.single_track ? "margin-top: -100px; margin-left: -1000px;" : "margin-left: -6px;"}"
      )
      (label
        :class "tr-c music-${pctl.playing ? "title" : "inactive" }"
        :text " َ°ژ† ${pctl.title_short}"
        :tooltip " َ°ژ† ${pctl.title} "
        :style "${pctl.single_track ? "margin-top: -100px; margin-left: -1000px;" : "margin-left: -6px; margin-right: -20px;"}"
      )
      (label
        :class "tr-c music-${pctl.playing ? "single" : "inactive" }"
        :text "َ°“ڈ ${pctl.album_short}"
        :tooltip " َ°“ڈ ${pctl.album} "
        :style "${pctl.single_track ? "margin-left: -38px; margin-right: -6px;" : "margin-top: -100px; margin-left: -1000px;"}"
      )
      (slide-n-fade
        :direction "left"
        :bool {hover == "music"}
        (music-volume :value {pctl.volume_percent})
      )
    )
  )
)

(defwidget music-progress []
  (box :class "music-progress" :space-evenly false :spacing 0
    :style "margin: 0 -9px;"
    (circular-progress
      :class "music-progress-circle${pctl.playing ? "" : "-paused" }"
      :value {pctl.progress}
      :start-at 75
      :thickness 2
      :clockwise true
      (box :class "music-progress-circle-icon"
        (eventbox
          :class "tr-a music-progress-circle-icon-${pctl.playing ? "playing" : "paused" }"
          :onclick "ewwd action music toggle"
          :onscroll "ewwd action music seek {}"
          :cursor "pointer"
          :tooltip "  َ°³½ play/pause آ· َ±•’ seek  "
          (label :text "${pctl.playing ? "َ°ڈ¦" : "َ°گچ"}")
        )
      )
    )
  )
)

(defwidget music-volume [value]
  (eventbox
    :onclick "ewwd action music volume set 1"
    :onmiddleclick "ewwd action music volume set 0.01"
    :onrightclick "ewwd action music volume set 0"
    :onscroll "ewwd action music volume {} 0.1"
    :cursor "pointer"
    :tooltip "  َ°³½ full آ· ا‚ minimum آ· َ°³¾ mute آ· َ±•’ adjust  "
    (box :style "margin-right: 4px;" :class "tr-c ramp-${
            value < 1   ? "1" :
            value < 30  ? "2" :
            value < 40  ? "3" :
            value < 50  ? "4" :
            value < 60  ? "5" :
            value < 70  ? "6" :
            value < 80  ? "7" :
            value < 90  ? "8" :
            value < 99  ? "9" : "10"
          }"
      (circular-progress
        :class "tr-c music-progress-circle"
        :value value
        :start-at 75
        :thickness 2
        :clockwise false
        (label
          :text {
            value == 0  ? "َ°–پ" :
            value < 35  ? "َ°•؟" :
            value < 65  ? "َ°–€" : "َ°•¾"
          }
          :style "
            font-size: ${value > 0 && value < 65 ? "22" : "20"}px;
            margin: ${
              value > 0 && value < 35 ? "8px 11px 7px 9px" :
                value < 65 ? "6px 9px 4px 7px" : "6px 6px 5px 7px"
            };
          "
        )
      )
    )
  )
)

;; ----------------------------------------------------------------------------
;; audio

(deflisten audio-info
  :initial '{"sink_available":false,"sink":0,"sink_name":"","sink_muted":false,"source_available":false,"source":0,"source_name":"","source_muted":false}'
  'ewwd subscribe audio | jq --unbuffered -c ".data"'
)

(deflisten bluetooth-info
  :initial '{"status":"unknown","name":"","battery_present":false,"battery_percent":0,"battery_charging":false,"noise_control_present":false,"noise_control":"","noise_pending":false,"noise_desired":"","wear_state":"","metadata_diagnostics":""}'
  'ewwd subscribe bluetooth | jq --unbuffered -c ".data"'
)

(defwidget audio []
  (eventbox
    :onhover "eww update hover=audio"
    :onhoverlost "eww update hover=''"
    (box
      :class "audio ${hover == "audio" ? "audio-hover" : ""}"
      :space-evenly false :spacing 10
      (audio-control
        :content "source"
        :value {audio-info.source}
        :name {audio-info.source_name}
        :available {audio-info.source_available}
        :muted {audio-info.source_muted}
        :icon-muted "ï„±"
        :icon-on "ï„°"
      )
      (audio-control
        :content "sink"
        :value {audio-info.sink}
        :name {audio-info.sink_name}
        :available {audio-info.sink_available}
        :muted {audio-info.sink_muted}
        :icon-on "َ°“ƒ"
        :icon-muted "َ°“„"
      )
      (headphones)
    )
  )
)

(defwidget audio-control [content value name available muted icon-muted icon-on]
  (eventbox
    :class "audio-${content}"
    :onclick {available ? "ewwd action audio reset_volume ${content}" : ""}
    :onrightclick {available ? "ewwd action audio toggle_mute ${content}" : ""}
    :onscroll {available ? "ewwd action audio change_volume ${content} {}" : ""}
    :cursor {available ? "pointer" : "default"}
    :tooltip "  ${available ? "َ°³½ reset آ· َ°³¾ mute آ· َ±•’ adjust" : "${content} unavailable"}  "
    (box
      :space-evenly false :spacing 9
      :class "tr-c audio-volume ${
        !available ? "audio-unavailable" :
        muted ? "audio-muted" :
        "ramp-${
          value < 1   ? "1" :
          value <= 10 ? "2" :
          value <= 30 ? "4" :
          value <= 40 ? "5" :
          value <= 50 ? "6" :
          value <= 60 ? "8" :
          value <= 70 ? "9" :
          value <= 80 ? "10" :
          value <= 90 ? "11" : "12"
        }"
      }"
      (circular-progress
        :class "music-progress-circle"
        :value {available ? (value <= 100 ? value : 100) : 0}
        :start-at 75
        :thickness 2
        :clockwise false
        (label
          :class "audio-${content}-icon${muted ? "-inactiveFix" : ""}"
          :text {muted ? icon-muted : icon-on}
        )
      )
      (slide-n-fade :bool {hover == "audio" && available} :direction "right"
        (label :class "audio-${content}-text" :text name)
      )
    )
  )
)

(defwidget headphones []
  (eventbox
    :onclick {bluetooth-info.noise_control_present ? "ewwd action bluetooth noise_cycle up" : ""}
    :onmiddleclick "ewwd action bluetooth toggle"
    :onscroll {bluetooth-info.noise_control_present ? "ewwd action bluetooth noise_cycle {}" : ""}
    :cursor "pointer"
    :tooltip "  ${bluetooth-info.noise_control_present ? "َ°³½ cycle mode آ· َ±•’ cycle mode آ· " : ""}ا‚ ${bluetooth-info.status == "connected" ? "disconnect" : "connect"}  "
    (box
      :space-evenly false :spacing 5
      :class "audio-headphones audio-headphones-${
        bluetooth-info.status == "unknown" ? "unknown" :
        bluetooth-info.status == "disconnected" ? "disconnected" :
        bluetooth-info.status == "connecting" ? "connecting" :
        !bluetooth-info.battery_present ? "unknown" :
        bluetooth-info.battery_percent < 20 ? "low" :
        bluetooth-info.battery_percent < 40 ? "warm" : "healthy"
      }"
      (label
        :class "audio-headphones-icon"
        :text {
          bluetooth-info.status == "unknown" ? "َ°‚³" :
          bluetooth-info.status == "disconnected" ? "َ°‚²" :
          bluetooth-info.status == "connecting" ? "َ°‚°" :
          !bluetooth-info.battery_present ? "َ°‚‘" :
          bluetooth-info.battery_percent < 20 ? "َ°‚ƒ" :
          bluetooth-info.battery_percent < 30 ? "َ°پ»" :
          bluetooth-info.battery_percent < 40 ? "َ°پ¼" :
          bluetooth-info.battery_percent < 50 ? "َ°پ½" :
          bluetooth-info.battery_percent < 60 ? "َ°پ¾" :
          bluetooth-info.battery_percent < 70 ? "َ°پ؟" :
          bluetooth-info.battery_percent < 80 ? "َ°‚€" :
          bluetooth-info.battery_percent < 90 ? "َ°‚پ" :
          bluetooth-info.battery_percent < 100 ? "َ°‚‚" : "َ°پ¹"
        }
      )
      (label
        :visible {bluetooth-info.status == "connected" && bluetooth-info.battery_present}
        :class "audio-headphones-percent"
        :text "${bluetooth-info.battery_percent}%"
      )
      (label
        :visible {
          bluetooth-info.status == "unknown" ||
          bluetooth-info.status == "connecting" ||
          (bluetooth-info.status == "connected" && !bluetooth-info.battery_present)
        }
        :class "audio-headphones-unknown"
        :text "â€“â€“"
      )
      (slide-n-fade :bool {hover == "audio" && bluetooth-info.status == "connected"} :direction "right"
        (box :space-evenly false :spacing 6
          (label
            :visible {bluetooth-info.noise_control_present}
            :class "audio-headphones-chip ${bluetooth-info.noise_pending ? "audio-headphones-chip-pending" : ""}"
            :text {
              (bluetooth-info.noise_pending ? bluetooth-info.noise_desired : bluetooth-info.noise_control) == "anc" ? "َ°©…" :
              (bluetooth-info.noise_pending ? bluetooth-info.noise_desired : bluetooth-info.noise_control) == "transparency" ? "َ°ں…" :
              (bluetooth-info.noise_pending ? bluetooth-info.noise_desired : bluetooth-info.noise_control) == "adaptive" ? "َ°•ک" : "َ°…–"
            }
          )
          (label
            :visible {bluetooth-info.wear_state == "not_worn"}
            :class "audio-headphones-wear"
            :tooltip "  Headphones are not worn  "
            :text "َ°‹‹"
          )
        )
      )
    )
  )
)
