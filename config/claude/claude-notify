#!/usr/bin/env bash
# dunst notifications for Claude Code hooks (settings.json)
# reads hook JSON via stdin for context-aware summaries,
# resolves workspace icons + kitty tab info per session
#
# sourced by sibling scripts (codex-notify) for shared infra

# ╭──────────────────────────────────────────────────────────────────────────────╮
# │ vars                                                                         │
# ╰──────────────────────────────────────────────────────────────────────────────╯

SOUND_DIR="$HOME/dotfiles/share/sounds"
QUIET=52428 # ~80% paplay volume (65536 = 100%)
LOUD=72089  # ~110%
ICON_DIR="$HOME/dotfiles/config/eww/art/ws-icons"
WINDOW_ID="${KITTY_WINDOW_ID:-}"
KITTY_PID="${KITTY_PID:-}"

# ╭──────────────────────────────────────────────────────────────────────────────╮
# │ context                                                                      │
# ╰──────────────────────────────────────────────────────────────────────────────╯

# Pull field $1 from HOOK_JSON, strip markdown, truncate to $3 chars
summary() {
    local field="$1" fallback="$2" max="${3:-80}"
    if [[ -n "$HOOK_JSON" ]]; then
        local val
        val=$(jq -r --arg f "$field" '.[$f] // empty' <<< "$HOOK_JSON" 2>/dev/null)
        if [[ -n "$val" ]]; then
            echo "$val" \
                | sed -E 's/^#{1,6} //; s/\*\*//g; s/`//g; s/^\s+//' \
                | grep -m1 '.' \
                | cut -c1-"$max"
            return
        fi
    fi
    echo "$fallback"
}

# ╭──────────────────────────────────────────────────────────────────────────────╮
# │ environment                                                                  │
# ╰──────────────────────────────────────────────────────────────────────────────╯

# Kitty tab icon (nerd font glyph extracted from decorators, used as app name)
tab_icon() {
    [[ -n "$WINDOW_ID" ]] && command -v kitty &>/dev/null || return 0
    local title icon
    title=$(kitty @ ls 2>/dev/null \
        | jq -r --arg w "$WINDOW_ID" \
            '.[] | .tabs[] | select(.windows[] | .id == ($w | tonumber)) | .title' \
            2>/dev/null) || return 0
    icon=$(sed -E 's/^[⊰⟜] (.*) [⊱⊸]$/\1/' <<< "$title" | xargs)
    [[ -n "$icon" ]] && echo "$icon"
}

# Workspace icon SVG (resolved from kitty window, not active ws)
ws_icon() {
    command -v hyprctl &>/dev/null || return 0
    local ws
    if [[ -n "$KITTY_PID" ]]; then
        ws=$(hyprctl clients -j 2>/dev/null \
            | jq -r --arg p "$KITTY_PID" \
                '[.[] | select(.pid == ($p | tonumber))] | .[0].workspace.id // empty' \
                2>/dev/null)
    else
        ws=$(hyprctl activeworkspace -j 2>/dev/null | jq -r '.id // empty' 2>/dev/null)
    fi
    local -A map=([1]=network [2]=learn [3]=dna [4]=dotfiles [5]=music)
    local name="${map[$ws]:-}" suffix="${1:-}"
    [[ -n "$name" ]] && echo "$ICON_DIR/${name}${suffix}.svg"
}

# ╭──────────────────────────────────────────────────────────────────────────────╮
# │ notification                                                                 │
# ╰──────────────────────────────────────────────────────────────────────────────╯

play() {
    local args=()
    [[ -n "${2:-}" ]] && args+=(--volume="$2")
    paplay "${args[@]}" "$SOUND_DIR/$1.ogg" & disown
}

notify() {
    local urgency="$1" timeout="$2" title="$3" body="$4"
    local bg="$5" fg="$6" fr="$7" icon_suffix="${8:-}"

    local icon icon_args=()
    icon=$(ws_icon "$icon_suffix")
    [[ -n "$icon" && -f "$icon" ]] && icon_args=(-I "$icon")

    local action
    action=$(dunstify -a "$APP" -u "$urgency" -t "$timeout" \
        -h "string:bgcolor:$bg" -h "string:fgcolor:$fg" -h "string:frcolor:$fr" \
        "${icon_args[@]}" -A "focus,Focus" \
        "$title" "$body")

    if [[ "$action" == "focus" && -n "$WINDOW_ID" ]]; then
        local log="/tmp/${APP}-notify.log"
        [[ -n "$KITTY_PID" ]] && hyprctl dispatch focuswindow pid:"$KITTY_PID" >>"$log" 2>&1
        kitty @ focus-window --match id:"$WINDOW_ID" >>"$log" 2>&1
    fi
}

# ╭──────────────────────────────────────────────────────────────────────────────╮
# │ palette                                                                      │
# ╰──────────────────────────────────────────────────────────────────────────────╯

BLU_BG="#25284180" BLU_FG="#8aa4f3" BLU_FR="#6380ec80"
ORN_BG="#49353130" ORN_FG="#f2a170" ORN_FR="#ea834b"
PRP_BG="#2a2d4580" PRP_FG="#b29ae8" PRP_FR="#9376d880"
GRN_BG="#2a3d2580" GRN_FG="#95cb79" GRN_FR="#73ad5a80"

# ── stop here when sourced ───────────────────────────────────────────────────────
[[ "${BASH_SOURCE[0]}" == "$0" ]] || return 0

# ╭──────────────────────────────────────────────────────────────────────────────╮
# │ dispatch                                                                     │
# ╰──────────────────────────────────────────────────────────────────────────────╯

TYPE="${1:-idle}"
MESSAGE="${2:-}"

HOOK_JSON=""
[[ ! -t 0 ]] && HOOK_JSON=$(cat)

APP=$(tab_icon)
APP="${APP:-claude}"

case "$TYPE" in
    start)
        sounds=(sdv-collect-item civ6-notification civ5-worker-select ssb-ready)
        pick="${sounds[$((RANDOM % ${#sounds[@]}))]}"
        play "$pick" "$QUIET"
        notify low 4000 "$(summary prompt "${MESSAGE:-$pick}")" "" \
            "$BLU_BG" "$BLU_FG" "$BLU_FR" "" </dev/null &>/dev/null & disown
        ;;
    subagent)
        play sdv-frog "$QUIET"
        agent=$(jq -r '.agent_type // "Agent"' <<< "$HOOK_JSON" 2>/dev/null)
        notify low 4000 "$agent: $(summary last_assistant_message Done 70)" "" \
            "$BLU_BG" "$BLU_FG" "$BLU_FR" "" </dev/null &>/dev/null & disown
        ;;
    complete)
        play jobs-done "$LOUD"
        notify low 0 "$(summary last_assistant_message 'Jobs done')" "" \
            "$ORN_BG" "$ORN_FG" "$ORN_FR" "-active" </dev/null &>/dev/null & disown
        ;;
    idle)
        play hey-listen "$QUIET"
        notify low 0 "$(summary message 'Waiting for input')" "" \
            "$PRP_BG" "$PRP_FG" "$PRP_FR" "" </dev/null &>/dev/null & disown
        ;;
    permission)
        play hey-listen "$LOUD"
        notify normal 0 "$(summary message 'Permission needed')" "" \
            "$GRN_BG" "$GRN_FG" "$GRN_FR" "-monocle" </dev/null &>/dev/null & disown
        ;;
esac
