{
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "allow": [
      "Read",
      "Edit",
      "Write",
      "Bash",
      "Glob",
      "Grep",
      "Task",
      "WebFetch",
      "WebSearch",
      "Skill"
    ],
    "defaultMode": "default"
  },
  "model": "claude-opus-4-6",
  "hooks": {
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "/home/cullyn/.local/bin/hyprd notify hook claude start"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "/home/cullyn/.local/bin/hyprd notify hook claude complete"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "/home/cullyn/.local/bin/hyprd notify hook claude subagent"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "permission_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "/home/cullyn/.local/bin/hyprd notify hook claude permission"
          }
        ]
      },
      {
        "matcher": "idle_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "/home/cullyn/.local/bin/hyprd notify hook claude idle"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "/home/cullyn/dotfiles/config/claude/statusline/statusline"
  },
  "enabledPlugins": {
    "gopls-lsp@claude-plugins-official": true
  },
  "outputStyle": "explanatory",
  "effortLevel": "medium",
  "promptSuggestionEnabled": false,
  "awaySummaryEnabled": false,
  "voiceEnabled": false,
  "preferredNotifChannel": "none",
  "shiftTabHint": false
}
