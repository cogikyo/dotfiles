{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": false,
  "enabled_providers": ["anthropic", "openai"],
  "model": "openai/gpt-5.5-fast",
  "small_model": "openai/gpt-5.5-fast",
  "default_agent": "drive",
  "share": "manual",
  "snapshot": true,
  "skills": {
    "paths": ["/home/cullyn/dotfiles/config/opencode/skills"]
  },
  "lsp": {
    "gopls": {
      "command": ["gopls"],
      "extensions": [".go"],
      "initialization": {
        "codelenses": {
          "tidy": false
        }
      }
    },
    "css": {
      "command": ["vscode-css-language-server", "--stdio"],
      "extensions": [".css", ".scss"]
    },
    "html": {
      "command": ["vscode-html-language-server", "--stdio"],
      "extensions": [".html"]
    },
    "json": {
      "command": ["vscode-json-language-server", "--stdio"],
      "extensions": [".json", ".jsonc"]
    },
    "marksman": {
      "command": ["marksman", "server"],
      "extensions": [".md", ".mdx"]
    },
    "tailwindcss": {
      "command": ["tailwindcss-language-server", "--stdio"],
      "extensions": [".html", ".css", ".js", ".jsx", ".ts", ".tsx"]
    },
    "taplo": {
      "command": ["taplo", "lsp", "stdio"],
      "extensions": [".toml"]
    },
    "yaml-ls": {
      "command": ["yaml-language-server", "--stdio"],
      "extensions": [".yaml", ".yml"]
    }
  },
  "formatter": {
    "prettier": {
      "disabled": true
    }
  },
  "plugin": [
    "file:///home/cullyn/dotfiles/config/opencode/plugins/hyprd/notify.ts",
    "file:///home/cullyn/dotfiles/config/opencode/plugins/opencode/media-context/prompt.ts"
  ],
  "provider": {
    "openai": {
      "models": {
        "gpt-5.5": {
          "options": {
            "serviceTier": "priority"
          }
        }
      }
    }
  },
  "permission": {
    "external_directory": {
      "~/**": "allow",
      "$HOME/**": "allow",
      "/home/cullyn/**": "allow",
      "/home/cullyn/.ssh/**": "deny",
      "/home/cullyn/.gnupg/**": "deny",
      "/home/cullyn/.password-store/**": "deny",
      "/home/cullyn/.local/share/keyrings/**": "deny",
      "/tmp/**": "allow"
    },
    "doom_loop": "ask",
    "bash": {
      "*": "allow",
      "rg *": "allow",
      "rm -r *": "deny",
      "rm -R *": "deny",
      "rm -f -r *": "deny",
      "rm -fR *": "deny",
      "rm -Rf *": "deny",
      "rm -fr *": "deny",
      "rm -rf *": "deny",
      "rm --recursive *": "deny",
      "sudo rm -r *": "deny",
      "sudo rm -R *": "deny",
      "sudo rm -f -r *": "deny",
      "sudo rm -fR *": "deny",
      "sudo rm -Rf *": "deny",
      "sudo rm -fr *": "deny",
      "sudo rm -rf *": "deny",
      "sudo rm --recursive *": "deny",
      "trash *": "allow",
      "trash-put *": "allow",
      "gio trash *": "allow",
      "git push --force*": "ask",
      "git push * --force*": "ask",
      "git push -f*": "ask",
      "git push * -f*": "ask",
      "git push --delete*": "ask",
      "git push * --delete*": "ask",
      "git reset --hard*": "ask",
      "git clean *": "ask",
      "git checkout -- *": "ask",
      "git restore *": "ask",
      "git commit --amend*": "ask",
      "git rebase *": "ask",
      "git branch -D *": "ask",
      "gh api --method GET *": "allow",
      "gh api -X GET *": "allow",
      "gh api * --method GET *": "allow",
      "gh api * -X GET *": "allow",
      "gh api --method POST *": "ask",
      "gh api --method PATCH *": "ask",
      "gh api --method PUT *": "ask",
      "gh api --method DELETE *": "ask",
      "gh api -X POST *": "ask",
      "gh api -X PATCH *": "ask",
      "gh api -X PUT *": "ask",
      "gh api -X DELETE *": "ask",
      "gh api * --method POST *": "ask",
      "gh api * --method PATCH *": "ask",
      "gh api * --method PUT *": "ask",
      "gh api * --method DELETE *": "ask",
      "gh api * -X POST *": "ask",
      "gh api * -X PATCH *": "ask",
      "gh api * -X PUT *": "ask",
      "gh api * -X DELETE *": "ask",
      "gh api * -f *": "ask",
      "gh api * -F *": "ask",
      "gh api * --field *": "ask",
      "gh api * --raw-field *": "ask",
      "git reflog expire *": "deny",
      "sudo *": "ask",
      "su *": "ask",
      "chmod *": "ask",
      "chown *": "ask",
      "pacman -Q*": "allow",
      "pacman --query*": "allow",
      "pacman -F*": "allow",
      "pacman --files*": "allow",
      "pacman -Si *": "allow",
      "pacman -Ss *": "allow",
      "pacman -Sl *": "allow",
      "pacman -Sp *": "allow",
      "pacman --sync --info *": "allow",
      "pacman --sync --search *": "allow",
      "pacman --sync --list *": "allow",
      "pacman --sync --print *": "allow",
      "pacman *": "ask",
      "yay *": "ask",
      "paru *": "ask",
      "npm install*": "ask",
      "pnpm install*": "ask",
      "yarn install*": "ask",
      "bun install*": "ask",
      "go install*": "ask",
      "go get*": "ask",
      "docker system prune*": "ask",
      "docker compose down*": "ask",
      "docker compose rm*": "ask",
      "docker compose pull*": "ask",
      "docker compose push*": "ask",
      "docker rm*": "ask",
      "docker rmi*": "ask",
      "docker volume rm*": "ask",
      "kubectl *": "ask",
      "helm *": "ask",
      "terraform apply*": "ask",
      "terraform destroy*": "ask"
    }
  },
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 10000
  },
  "watcher": {
    "ignore": [".git/**", "node_modules/**", "dist/**", "build/**"]
  }
}
