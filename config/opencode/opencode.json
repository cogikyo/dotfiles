{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": false,
  "enabled_providers": ["anthropic", "openai", "xai", "opencode-go", "kimi-code"],
  "model": "openai/gpt-5.6-sol-fast",
  "small_model": "openai/gpt-5.4-mini-fast",
  "default_agent": "collab",
  "agent": {
    "build": { "disable": true },
    "plan": { "disable": true }
  },
  "share": "manual",
  "snapshot": true,
  "lsp": false,
  "formatter": {
    "prettier": {
      "disabled": true
    }
  },
  "plugin": [
    "opencode-claude-auth@1.5.4",
    "file:///home/cullyn/dotfiles/config/opencode/plugins/delegate/index.ts",
    "file:///home/cullyn/dotfiles/config/opencode/plugins/usage/tool.ts",
    "file:///home/cullyn/dotfiles/config/opencode/plugins/x/tool.ts",
    "file:///home/cullyn/dotfiles/config/opencode/plugins/hyprd/notify.ts",
    "file:///home/cullyn/dotfiles/config/opencode/plugins/opencode/spec-title.ts",
    [
      "file:///home/cullyn/dotfiles/config/opencode/plugins/opencode/media-context/prompt.ts",
      { "imageNames": { "enabled": true } }
    ]
  ],
  "provider": {
    "kimi-code": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Kimi Code",
      "options": {
        "baseURL": "https://api.kimi.com/coding/v1"
      },
      "models": {
        "k3": {
          "name": "Kimi K3",
          "reasoning": true,
          "options": {
            "reasoningEffort": "max"
          },
          "variants": {
            "low": { "reasoningEffort": "low" },
            "high": { "reasoningEffort": "high" },
            "max": { "reasoningEffort": "max" }
          },
          "limit": {
            "context": 262144,
            "output": 131072
          }
        }
      }
    },
    "openai": {
      "models": {
        "gpt-5.6-sol": {
          "options": {
            "serviceTier": "priority"
          }
        },
        "gpt-5.6-terra": {
          "options": {
            "serviceTier": "priority"
          }
        }
      }
    },
    "xai": {
      "models": {
        "grok-4.5": {
          "name": "Grok 4.5",
          "options": {
            "reasoningEffort": "high"
          },
          "variants": {
            "low": { "reasoningEffort": "low" },
            "medium": { "reasoningEffort": "medium" },
            "high": { "reasoningEffort": "high" }
          }
        }
      }
    }
  },
  "permission": {
    "spec_title": "deny",
    "grok_x": "deny",
    "external_directory": {
      "/": "deny",
      "/?": "deny",
      "~/**": "allow",
      "$HOME/**": "allow",
      "/home/cullyn/**": "allow",
      "/usr": "allow",
      "/usr/**": "allow",
      "/var/cache/pacman/pkg/**": "allow",
      "/home/cullyn/.ssh/**": "deny",
      "/home/cullyn/.gnupg/**": "deny",
      "/home/cullyn/.password-store/**": "deny",
      "/home/cullyn/.local/share/keyrings/**": "deny",
      "/run/user/1000/opencode": "allow",
      "/run/user/1000/opencode/**": "allow",
      "/tmp/**": "allow"
    },
    "doom_loop": "ask",
    "webfetch": "allow",
    "websearch": "allow",
    "skill": "allow",
    "lsp": "deny",
    "grep": {
      "*": "allow",
      "/": "deny"
    },
    "bash": {
      "*": "allow",
      "rg *": "allow",
      "rm -r *": "deny",
      "rm -R *": "deny",
      "rm -f -r *": "deny",
      "rm -fR *": "deny",
      "rm -Rf *": "deny",
      "rm -fr *": "deny",
      "rm -rf *": "deny",
      "rm --recursive *": "deny",
      "sudo rm -r *": "deny",
      "sudo rm -R *": "deny",
      "sudo rm -f -r *": "deny",
      "sudo rm -fR *": "deny",
      "sudo rm -Rf *": "deny",
      "sudo rm -fr *": "deny",
      "sudo rm -rf *": "deny",
      "sudo rm --recursive *": "deny",
      "trash *": "allow",
      "trash-put *": "allow",
      "gio trash *": "allow",
      "git push*": "deny",
      "* git push*": "deny",
      "git -C * push*": "deny",
      "git reset --hard*": "ask",
      "git clean *": "ask",
      "git checkout -- *": "ask",
      "git restore *": "ask",
      "git commit --amend*": "ask",
      "git rebase *": "ask",
      "git filter-branch*": "ask",
      "git branch -D *": "ask",
      "gh api --method GET *": "allow",
      "gh api -X GET *": "allow",
      "gh api * --method GET *": "allow",
      "gh api * -X GET *": "allow",
      "gh api --method POST *": "ask",
      "gh api --method PATCH *": "ask",
      "gh api --method PUT *": "ask",
      "gh api --method DELETE *": "ask",
      "gh api -X POST *": "ask",
      "gh api -X PATCH *": "ask",
      "gh api -X PUT *": "ask",
      "gh api -X DELETE *": "ask",
      "gh api * --method POST *": "ask",
      "gh api * --method PATCH *": "ask",
      "gh api * --method PUT *": "ask",
      "gh api * --method DELETE *": "ask",
      "gh api * -X POST *": "ask",
      "gh api * -X PATCH *": "ask",
      "gh api * -X PUT *": "ask",
      "gh api * -X DELETE *": "ask",
      "gh api * -f *": "ask",
      "gh api * -F *": "ask",
      "gh api * --field *": "ask",
      "gh api * --raw-field *": "ask",
      "git reflog expire *": "deny",
      "sudo *": "ask",
      "su *": "ask",
      "chmod *": "ask",
      "chown *": "ask",
      "pacman *": "ask",
      "pacman -Q*": "allow",
      "pacman --query*": "allow",
      "pacman -F *": "allow",
      "pacman -Si *": "allow",
      "pacman -Ss *": "allow",
      "pacman -Sl *": "allow",
      "pacman -Sp *": "allow",
      "pacman --sync --info *": "allow",
      "pacman --sync --search *": "allow",
      "pacman --sync --list *": "allow",
      "pacman --sync --print *": "allow",
      "yay *": "ask",
      "paru *": "ask",
      "npm install*": "ask",
      "pnpm install*": "ask",
      "yarn install*": "ask",
      "bun install*": "ask",
      "go install*": "ask",
      "go get*": "ask",
      "docker system prune*": "ask",
      "docker compose down*": "ask",
      "docker compose rm*": "ask",
      "docker compose pull*": "ask",
      "docker compose push*": "ask",
      "docker rm*": "ask",
      "docker rmi*": "ask",
      "docker volume rm*": "ask",
      "kubectl *": "ask",
      "helm *": "ask",
      "terraform apply*": "ask",
      "terraform destroy*": "ask"
    }
  },
  "experimental": {
    "primary_tools": ["usage_status"]
  },
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 10000
  },
  "watcher": {
    "ignore": [".git/**", "node_modules/**", "dist/**", "build/**"]
  }
}
