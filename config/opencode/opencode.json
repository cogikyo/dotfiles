{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": "notify",
  "share": "manual",
  "snapshot": true,
  "skills": {
    "paths": [
      "{env:HOME}/dotfiles/skills/user"
    ]
  },
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 10000
  },
  "watcher": {
    "ignore": [
      ".git/**",
      "node_modules/**",
      "dist/**",
      "build/**"
    ]
  }
}
