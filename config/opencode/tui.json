{
  "$schema": "https://opencode.ai/tui.json",
  "theme": "vagari",
  "plugin": [
    "file:///home/cullyn/dotfiles/config/opencode/plugins/hyprd/kitty.ts",
    "file:///home/cullyn/dotfiles/config/opencode/plugins/openai/usage.tsx",
    "file:///home/cullyn/dotfiles/config/opencode/plugins/opencode/statusline.tsx"
  ],
  "mouse": true,
  "diff_style": "auto",
  "scroll_speed": 3,
  "scroll_acceleration": {
    "enabled": true
  },
  "keybinds": {
    "leader": "ctrl+space",
    "command_list": "<leader>l",
    "tool_details": "<leader>d",
    "model_list": "<leader>m",
    "theme_list": "<leader>_",
    "agent_list": "<leader>a",
    "session_list": "<leader>r",
    "status_view": "<leader>s",
    "input_line_home": "home,ctrl+a",
    "input_line_end": "end,ctrl+e",
    "input_select_line_home": "shift+home,ctrl+shift+a",
    "input_select_line_end": "shift+end,ctrl+shift+e",
    "input_buffer_home": "alt+home",
    "input_buffer_end": "alt+end",
    "input_select_buffer_home": "alt+shift+home",
    "input_select_buffer_end": "alt+shift+end",
    "session_share": "none",
    "session_unshare": "none"
  }
}
