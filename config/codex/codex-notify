#!/usr/bin/env bash
# dunst notifications for Codex CLI
# sources shared notification infra from claude-notify
#
# entry points:
#   1. codex notify hook  →  codex-notify '{"type":"agent-turn-complete",...}'
#   2. dunst script rule  →  codex-notify approval  (kitty OSC 99 intercept)
#
# codex spawns notify scripts with restricted env — re-export session vars
# for D-Bus (dunstify) and PulseAudio (paplay)

LOG="/tmp/codex-notify.log"
exec >> "$LOG" 2>&1

DBUS_SESSION_BUS_ADDRESS="unix:path=/run/user/$(id -u)/bus"
export DBUS_SESSION_BUS_ADDRESS
XDG_RUNTIME_DIR="/run/user/$(id -u)"
export XDG_RUNTIME_DIR

echo "--- $(date) ---"
echo "DBUS=$DBUS_SESSION_BUS_ADDRESS"
echo "XDG=$XDG_RUNTIME_DIR"
echo "args: $*"
echo "which dunstify: $(which dunstify 2>&1)"

# shellcheck source=../claude/claude-notify
source "$(dirname "${BASH_SOURCE[0]}")/../claude/claude-notify"

# Dunst script mode: dunst passes (appname, summary, body, icon, urgency)
# when intercepting kitty's OSC 99 "Approval requested" notification
if [[ "${1:-}" == "kitty" && "${2:-}" == *Approval* ]]; then
    HOOK_JSON='{}'
    TYPE="approval-requested"
    # Dunst has no kitty env — find the kitty instance running codex
    for sock in /tmp/kitty-*; do
        [[ -S "$sock" ]] || continue
        WINDOW_ID=$(kitty @ --to "unix:$sock" ls 2>/dev/null \
            | jq -r '[.[].tabs[].windows[]
                | select(.foreground_processes[].cmdline[] | test("codex"))]
                | .[0].id // empty' 2>/dev/null)
        if [[ -n "$WINDOW_ID" ]]; then
            export KITTY_LISTEN_ON="unix:$sock"
            KITTY_PID="${sock##*-}"
            break
        fi
    done
else
    HOOK_JSON="$1"
    [[ -z "$HOOK_JSON" ]] && HOOK_JSON='{}'
    TYPE=$(jq -r '.type // empty' <<< "$HOOK_JSON" 2>/dev/null)
fi

APP=$(tab_icon)
APP="${APP:-codex}"

case "$TYPE" in
    agent-turn-start)
        sounds=(zug-zug work-work okie-dokie something-need-doing)
        pick="${sounds[$((RANDOM % ${#sounds[@]}))]}"
        play "$pick" "$QUIET"
        notify low 4000 "$(summary last-assistant-message "$pick")" "" \
            "$BLU_BG" "$BLU_FG" "$BLU_FR" "" </dev/null &>/dev/null & disown
        ;;
    agent-turn-complete)
        play jobs-done "$LOUD"
        notify low 0 "$(summary last-assistant-message 'Jobs done')" "" \
            "$ORN_BG" "$ORN_FG" "$ORN_FR" "-active" </dev/null &>/dev/null & disown
        ;;
    idle)
        play hey-listen "$QUIET"
        notify low 0 "$(summary last-assistant-message 'Waiting for input')" "" \
            "$PRP_BG" "$PRP_FG" "$PRP_FR" "" </dev/null &>/dev/null & disown
        ;;
    approval-requested)
        # delay: dunstify blocks when called from within a dunst script handler
        (sleep 0.3
        play hey-listen "$LOUD"
        notify normal 0 "Permission needed" "" \
            "$GRN_BG" "$GRN_FG" "$GRN_FR" "-monocle") &disown
        ;;
esac
