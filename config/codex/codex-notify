#!/usr/bin/env bash
# dunst notifications for Codex CLI (config.toml notify)
# sources shared notification infra from claude-notify
#
# codex spawns notify scripts with restricted env — re-export session vars
# for D-Bus (dunstify) and PulseAudio (paplay)

export DBUS_SESSION_BUS_ADDRESS="unix:path=/run/user/$(id -u)/bus"
export XDG_RUNTIME_DIR="/run/user/$(id -u)"

# shellcheck source=../claude/claude-notify
source "$(dirname "${BASH_SOURCE[0]}")/../claude/claude-notify"

HOOK_JSON="$1"
[[ -z "$HOOK_JSON" ]] && HOOK_JSON='{}'

TYPE=$(jq -r '.type // empty' <<< "$HOOK_JSON" 2>/dev/null)

APP=$(tab_icon)
APP="${APP:-codex}"

case "$TYPE" in
    agent-turn-start)
        sounds=(zug-zug work-work okie-dokie something-need-doing)
        pick="${sounds[$((RANDOM % ${#sounds[@]}))]}"
        play "$pick" "$QUIET"
        notify low 4000 "$(summary last-assistant-message "$pick")" "" \
            "$BLU_BG" "$BLU_FG" "$BLU_FR" &
        ;;
    agent-turn-complete)
        play jobs-done "$LOUD"
        notify low 0 "$(summary last-assistant-message 'Jobs done')" "" \
            "$ORN_BG" "$ORN_FG" "$ORN_FR" &
        ;;
    idle)
        play hey-listen "$QUIET"
        notify low 0 "$(summary last-assistant-message 'Waiting for input')" "" \
            "$PRP_BG" "$PRP_FG" "$PRP_FR" &
        ;;
    approval-requested)
        play hey-listen "$LOUD"
        notify normal 0 "$(summary last-assistant-message 'Permission needed')" "" \
            "$GRN_BG" "$GRN_FG" "$GRN_FR" &
        ;;
esac
