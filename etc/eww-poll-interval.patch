+/// Default poll interval for builtin vars, overridable at compile time via
+/// `EWW_POLL_INTERVAL_MS` environment variable (default: 2000).
+/// Uses a build script to pass the value as a cfg so we avoid needing const parsing crates.
+fn builtin_poll_interval_ms() -> u64 {
+    option_env!("EWW_POLL_INTERVAL_MS")
+        .and_then(|v| v.parse().ok())
+        .unwrap_or(2000)
+}
