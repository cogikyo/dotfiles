diff --git a/linux-rust/src/metadata.rs b/linux-rust/src/metadata.rs
--- /dev/null
+++ b/linux-rust/src/metadata.rs
@@ -0,0 +1,645 @@
+//! Session-bus metadata exporter for the active AirPods session.
+//!
+//! State is rebuilt from `AACPManagerState` after relevant events.
+//! An internal session token prevents delayed updates from an old connection
+//! to an address from changing the replacement connection's snapshot.
+
+use std::borrow::Cow;
+use std::collections::HashMap;
+use std::sync::atomic::{AtomicU64, Ordering};
+
+use crate::bluetooth::aacp::{
+    AACPEvent, AACPManager, BatteryComponent, BatteryInfo, BatteryStatus,
+    ControlCommandIdentifiers, ControlCommandStatus, EarDetectionStatus,
+};
+use log::{info, warn};
+use tokio::sync::mpsc::{UnboundedReceiver, UnboundedSender, unbounded_channel};
+use zbus::object_server::InterfaceRef;
+use zbus::zvariant::Value;
+
+pub const BUS_NAME: &str = "me.kavishdevar.librepods";
+pub const OBJECT_PATH: &str = "/me/kavishdevar/librepods";
+pub const INTERFACE_VERSION: u32 = 1;
+
+const MODE_OFF: &str = "off";
+const MODE_ANC: &str = "anc";
+const MODE_TRANSPARENCY: &str = "transparency";
+const MODE_ADAPTIVE: &str = "adaptive";
+
+const READINESS_INITIALIZING: &str = "initializing";
+const READINESS_READY: &str = "ready";
+const READINESS_DISCONNECTED: &str = "disconnected";
+
+const WEAR_UNKNOWN: &str = "unknown";
+const WEAR_WORN: &str = "worn";
+const WEAR_NOT_WORN: &str = "not_worn";
+
+fn mode_name(byte: u8) -> Option<&'static str> {
+    match byte {
+        0x01 => Some(MODE_OFF),
+        0x02 => Some(MODE_ANC),
+        0x03 => Some(MODE_TRANSPARENCY),
+        0x04 => Some(MODE_ADAPTIVE),
+        _ => None,
+    }
+}
+
+fn mode_byte(mode: &str) -> Option<u8> {
+    match mode {
+        MODE_OFF => Some(0x01),
+        MODE_ANC => Some(0x02),
+        MODE_TRANSPARENCY => Some(0x03),
+        MODE_ADAPTIVE => Some(0x04),
+        _ => None,
+    }
+}
+
+#[derive(Clone, Copy, Debug, Eq, PartialEq)]
+pub struct Session(u64);
+
+impl Session {
+    fn new() -> Self {
+        static NEXT: AtomicU64 = AtomicU64::new(1);
+        Self(NEXT.fetch_add(1, Ordering::Relaxed))
+    }
+
+    fn generation(self) -> String {
+        format!("{}-{}", std::process::id(), self.0)
+    }
+}
+
+#[derive(Debug, zbus::DBusError)]
+#[zbus(prefix = "me.kavishdevar.librepods.Error")]
+enum CommandError {
+    #[zbus(error)]
+    ZBus(zbus::Error),
+    NoDevice(String),
+    StaleGeneration(String),
+    Unsupported(String),
+    QueueUnavailable(String),
+}
+
+enum Update {
+    Connected {
+        addr: String,
+        session: Session,
+        aacp: AACPManager,
+    },
+    Disconnected {
+        addr: String,
+        session: Session,
+    },
+    Event {
+        addr: String,
+        session: Session,
+    },
+}
+
+struct Command {
+    aacp: AACPManager,
+    identifier: ControlCommandIdentifiers,
+    value: Vec<u8>,
+}
+
+#[derive(Clone)]
+pub struct Handle {
+    tx: UnboundedSender<Update>,
+}
+
+impl Handle {
+    pub fn connected(&self, addr: String, aacp: AACPManager) -> Session {
+        let session = Session::new();
+        let _ = self.tx.send(Update::Connected {
+            addr,
+            session,
+            aacp,
+        });
+        session
+    }
+
+    pub fn disconnected(&self, addr: String, session: Session) {
+        let _ = self.tx.send(Update::Disconnected { addr, session });
+    }
+
+    pub fn event(&self, addr: String, session: Session, event: &AACPEvent) {
+        if matches!(event, AACPEvent::Disconnected) {
+            self.disconnected(addr, session);
+            return;
+        }
+        if !matches!(
+            event,
+            AACPEvent::BatteryInfo(_)
+                | AACPEvent::ControlCommand(_)
+                | AACPEvent::EarDetection(_, _)
+                | AACPEvent::HiResMic(_)
+        ) {
+            return;
+        }
+        let _ = self.tx.send(Update::Event { addr, session });
+    }
+}
+
+#[derive(Clone, PartialEq)]
+struct Snapshot {
+    generation: String,
+    address: String,
+    readiness: String,
+    battery_percent: u8,
+    battery_valid: bool,
+    battery_charging: bool,
+    noise_control: String,
+    noise_control_modes: Vec<String>,
+    wear: String,
+    conversation_awareness_supported: bool,
+    conversation_awareness_enabled: bool,
+    personalized_volume_supported: bool,
+    personalized_volume_enabled: bool,
+    hires_mic_supported: bool,
+    hires_mic_enabled: bool,
+}
+
+impl Snapshot {
+    fn idle() -> Self {
+        Self {
+            generation: String::new(),
+            address: String::new(),
+            readiness: READINESS_DISCONNECTED.to_owned(),
+            battery_percent: 0,
+            battery_valid: false,
+            battery_charging: false,
+            noise_control: String::new(),
+            noise_control_modes: Vec::new(),
+            wear: WEAR_UNKNOWN.to_owned(),
+            conversation_awareness_supported: false,
+            conversation_awareness_enabled: false,
+            personalized_volume_supported: false,
+            personalized_volume_enabled: false,
+            hires_mic_supported: false,
+            hires_mic_enabled: false,
+        }
+    }
+
+    fn initializing(session: Session, address: String) -> Self {
+        Self {
+            generation: session.generation(),
+            address,
+            readiness: READINESS_INITIALIZING.to_owned(),
+            ..Self::idle()
+        }
+    }
+
+    fn property_values(&self) -> HashMap<&'static str, Value<'static>> {
+        HashMap::from([
+            ("SessionGeneration", Value::from(self.generation.clone())),
+            ("DeviceAddress", Value::from(self.address.clone())),
+            ("Readiness", Value::from(self.readiness.clone())),
+            ("BatteryPercent", Value::from(self.battery_percent)),
+            ("BatteryValid", Value::from(self.battery_valid)),
+            ("BatteryCharging", Value::from(self.battery_charging)),
+            ("NoiseControl", Value::from(self.noise_control.clone())),
+            (
+                "NoiseControlModes",
+                Value::from(self.noise_control_modes.clone()),
+            ),
+            ("WearState", Value::from(self.wear.clone())),
+            (
+                "ConversationAwarenessSupported",
+                Value::from(self.conversation_awareness_supported),
+            ),
+            (
+                "ConversationAwarenessEnabled",
+                Value::from(self.conversation_awareness_enabled),
+            ),
+            (
+                "PersonalizedVolumeSupported",
+                Value::from(self.personalized_volume_supported),
+            ),
+            (
+                "PersonalizedVolumeEnabled",
+                Value::from(self.personalized_volume_enabled),
+            ),
+            ("HiResMicSupported", Value::from(self.hires_mic_supported)),
+            ("HiResMicEnabled", Value::from(self.hires_mic_enabled)),
+        ])
+    }
+}
+
+#[derive(Clone)]
+struct Active {
+    address: String,
+    session: Session,
+    aacp: AACPManager,
+}
+
+struct Metadata {
+    snap: Snapshot,
+    active: Option<Active>,
+    commands: UnboundedSender<Command>,
+}
+
+impl Metadata {
+    fn new(commands: UnboundedSender<Command>) -> Self {
+        Self {
+            snap: Snapshot::idle(),
+            active: None,
+            commands,
+        }
+    }
+
+    fn session(&self, generation: &str) -> Result<&Active, CommandError> {
+        let Some(active) = &self.active else {
+            return Err(CommandError::NoDevice(
+                "no active AirPods session".to_owned(),
+            ));
+        };
+        if generation != self.snap.generation {
+            return Err(CommandError::StaleGeneration(format!(
+                "generation {generation:?} was superseded"
+            )));
+        }
+        Ok(active)
+    }
+
+    async fn begin_session(&mut self, addr: String, session: Session, aacp: AACPManager) {
+        self.snap = Snapshot::initializing(session, addr.clone());
+        self.active = Some(Active {
+            address: addr,
+            session,
+            aacp,
+        });
+        self.refresh().await;
+    }
+
+    async fn refresh(&mut self) {
+        let Some(active) = self.active.clone() else {
+            return;
+        };
+        let state = active.aacp.state.lock().await;
+        let statuses = state.control_command_status_list.clone();
+        let battery = state.battery_info.clone();
+        let ear = state.ear_detection_status.clone();
+        let aacp_connected = state.sender.is_some();
+        drop(state);
+
+        let mut snap = Snapshot::initializing(active.session, active.address);
+        if !statuses.is_empty() || !battery.is_empty() || !ear.is_empty() {
+            snap.readiness = READINESS_READY.to_owned();
+        }
+        apply_battery(&mut snap, &battery);
+        apply_controls(&mut snap, &statuses);
+        apply_wear(&mut snap, &ear);
+        snap.hires_mic_supported = aacp_connected;
+        snap.hires_mic_enabled = aacp_connected && active.aacp.hires_mic_enabled();
+        self.snap = snap;
+    }
+
+    fn end_session(&mut self) {
+        self.active = None;
+        self.snap = Snapshot::idle();
+    }
+
+    fn enqueue(
+        &self,
+        active: &Active,
+        identifier: ControlCommandIdentifiers,
+        value: Vec<u8>,
+    ) -> Result<(), CommandError> {
+        self.commands
+            .send(Command {
+                aacp: active.aacp.clone(),
+                identifier,
+                value,
+            })
+            .map_err(|_| CommandError::QueueUnavailable("command worker stopped".to_owned()))
+    }
+}
+
+fn apply_battery(snap: &mut Snapshot, info: &[BatteryInfo]) {
+    let pick = |component: BatteryComponent| {
+        info.iter()
+            .find(|b| b.component == component && b.status != BatteryStatus::Disconnected)
+    };
+    let charging = |b: Option<&BatteryInfo>| b.is_some_and(|b| b.status == BatteryStatus::Charging);
+
+    let (level, is_charging) = match pick(BatteryComponent::Headphone) {
+        Some(b) => (Some(b.level), b.status == BatteryStatus::Charging),
+        None => {
+            let left = pick(BatteryComponent::Left);
+            let right = pick(BatteryComponent::Right);
+            let level = match (left, right) {
+                (Some(left), Some(right)) => Some(left.level.min(right.level)),
+                (Some(b), None) | (None, Some(b)) => Some(b.level),
+                (None, None) => None,
+            };
+            (level, charging(left) || charging(right))
+        }
+    };
+
+    if let Some(level) = level {
+        snap.battery_percent = level;
+        snap.battery_valid = true;
+        snap.battery_charging = is_charging;
+    }
+}
+
+fn apply_controls(snap: &mut Snapshot, statuses: &[ControlCommandStatus]) {
+    let status = |identifier| statuses.iter().find(|s| s.identifier == identifier);
+    snap.noise_control = status(ControlCommandIdentifiers::ListeningMode)
+        .and_then(|s| s.value.first())
+        .and_then(|value| mode_name(*value))
+        .unwrap_or_default()
+        .to_owned();
+
+    if let Some(mask) = status(ControlCommandIdentifiers::ListeningModeConfigs)
+        .and_then(|s| s.value.first())
+        .copied()
+    {
+        for (bit, mode) in [
+            (0x01, MODE_OFF),
+            (0x02, MODE_ANC),
+            (0x04, MODE_TRANSPARENCY),
+            (0x08, MODE_ADAPTIVE),
+        ] {
+            if mask & bit != 0 {
+                snap.noise_control_modes.push(mode.to_owned());
+            }
+        }
+    }
+
+    if let Some(value) =
+        status(ControlCommandIdentifiers::ConversationDetectConfig).and_then(|s| s.value.first())
+    {
+        snap.conversation_awareness_supported = true;
+        snap.conversation_awareness_enabled = *value == 0x01;
+    }
+    if let Some(value) =
+        status(ControlCommandIdentifiers::AdaptiveVolumeConfig).and_then(|s| s.value.first())
+    {
+        snap.personalized_volume_supported = true;
+        snap.personalized_volume_enabled = *value == 0x01;
+    }
+}
+
+fn apply_wear(snap: &mut Snapshot, statuses: &[EarDetectionStatus]) {
+    let known: Vec<_> = statuses
+        .iter()
+        .filter(|status| **status != EarDetectionStatus::Disconnected)
+        .collect();
+    snap.wear = if known.is_empty() {
+        WEAR_UNKNOWN
+    } else if known
+        .iter()
+        .any(|status| **status == EarDetectionStatus::InEar)
+    {
+        WEAR_WORN
+    } else {
+        WEAR_NOT_WORN
+    }
+    .to_owned();
+}
+
+#[zbus::interface(name = "me.kavishdevar.librepods.Metadata1")]
+impl Metadata {
+    #[zbus(property)]
+    fn interface_version(&self) -> u32 {
+        INTERFACE_VERSION
+    }
+
+    #[zbus(property)]
+    fn session_generation(&self) -> String {
+        self.snap.generation.clone()
+    }
+
+    #[zbus(property)]
+    fn device_address(&self) -> String {
+        self.snap.address.clone()
+    }
+
+    #[zbus(property)]
+    fn readiness(&self) -> String {
+        self.snap.readiness.clone()
+    }
+
+    #[zbus(property)]
+    fn battery_percent(&self) -> u8 {
+        self.snap.battery_percent
+    }
+
+    #[zbus(property)]
+    fn battery_valid(&self) -> bool {
+        self.snap.battery_valid
+    }
+
+    #[zbus(property)]
+    fn battery_charging(&self) -> bool {
+        self.snap.battery_charging
+    }
+
+    #[zbus(property)]
+    fn noise_control(&self) -> String {
+        self.snap.noise_control.clone()
+    }
+
+    #[zbus(property)]
+    fn noise_control_modes(&self) -> Vec<String> {
+        self.snap.noise_control_modes.clone()
+    }
+
+    #[zbus(property)]
+    fn wear_state(&self) -> String {
+        self.snap.wear.clone()
+    }
+
+    #[zbus(property)]
+    fn conversation_awareness_supported(&self) -> bool {
+        self.snap.conversation_awareness_supported
+    }
+
+    #[zbus(property)]
+    fn conversation_awareness_enabled(&self) -> bool {
+        self.snap.conversation_awareness_enabled
+    }
+
+    #[zbus(property)]
+    fn personalized_volume_supported(&self) -> bool {
+        self.snap.personalized_volume_supported
+    }
+
+    #[zbus(property)]
+    fn personalized_volume_enabled(&self) -> bool {
+        self.snap.personalized_volume_enabled
+    }
+
+    #[zbus(property)]
+    fn hi_res_mic_supported(&self) -> bool {
+        self.snap.hires_mic_supported
+    }
+
+    #[zbus(property)]
+    fn hi_res_mic_enabled(&self) -> bool {
+        self.snap.hires_mic_enabled
+    }
+
+    fn select_noise_control(&self, generation: String, mode: String) -> Result<(), CommandError> {
+        let active = self.session(&generation)?;
+        let Some(byte) = mode_byte(&mode) else {
+            return Err(CommandError::Unsupported(format!(
+                "unknown noise-control mode {mode:?}"
+            )));
+        };
+        if !self
+            .snap
+            .noise_control_modes
+            .iter()
+            .any(|item| item == &mode)
+        {
+            return Err(CommandError::Unsupported(format!(
+                "noise-control mode {mode:?} is not reported by the device"
+            )));
+        }
+        self.enqueue(active, ControlCommandIdentifiers::ListeningMode, vec![byte])
+    }
+
+    fn cycle_noise_control(&self, generation: String) -> Result<String, CommandError> {
+        let active = self.session(&generation)?;
+        let modes = &self.snap.noise_control_modes;
+        if modes.is_empty() {
+            return Err(CommandError::Unsupported(
+                "device has not reported supported noise-control modes".to_owned(),
+            ));
+        }
+        let target = match modes
+            .iter()
+            .position(|mode| *mode == self.snap.noise_control)
+        {
+            Some(index) => modes[(index + 1) % modes.len()].clone(),
+            None => modes[0].clone(),
+        };
+        self.enqueue(
+            active,
+            ControlCommandIdentifiers::ListeningMode,
+            vec![mode_byte(&target).expect("device modes are validated")],
+        )?;
+        Ok(target)
+    }
+}
+
+pub fn spawn() -> Handle {
+    let (tx, rx) = unbounded_channel();
+    let (command_tx, command_rx) = unbounded_channel();
+    tokio::spawn(command_worker(command_rx));
+    tokio::spawn(async move {
+        if let Err(error) = serve(rx, command_tx).await {
+            warn!("metadata service unavailable: {error}");
+        }
+    });
+    Handle { tx }
+}
+
+async fn command_worker(mut rx: UnboundedReceiver<Command>) {
+    while let Some(command) = rx.recv().await {
+        if let Err(error) = command
+            .aacp
+            .send_control_command(command.identifier, &command.value)
+            .await
+        {
+            warn!("metadata command failed: {error}");
+        }
+    }
+}
+
+async fn serve(
+    mut rx: UnboundedReceiver<Update>,
+    commands: UnboundedSender<Command>,
+) -> zbus::Result<()> {
+    let conn = zbus::connection::Builder::session()?
+        .name(BUS_NAME)?
+        .serve_at(OBJECT_PATH, Metadata::new(commands))?
+        .build()
+        .await?;
+    let iface: InterfaceRef<Metadata> = conn.object_server().interface(OBJECT_PATH).await?;
+    info!("metadata service listening on {BUS_NAME} at {OBJECT_PATH}");
+
+    while let Some(update) = rx.recv().await {
+        let mut metadata = iface.get_mut().await;
+        let before = metadata.snap.clone();
+        match update {
+            Update::Connected {
+                addr,
+                session,
+                aacp,
+            } => metadata.begin_session(addr, session, aacp).await,
+            Update::Disconnected { addr, session } => {
+                if metadata
+                    .active
+                    .as_ref()
+                    .is_some_and(|active| active.address == addr && active.session == session)
+                {
+                    metadata.end_session();
+                }
+            }
+            Update::Event { addr, session } => {
+                if metadata
+                    .active
+                    .as_ref()
+                    .is_some_and(|active| active.address == addr && active.session == session)
+                {
+                    metadata.refresh().await;
+                }
+            }
+        }
+        let changed = metadata.snap != before;
+        let properties = metadata.snap.property_values();
+        drop(metadata);
+
+        if changed
+            && let Err(error) = zbus::fdo::Properties::properties_changed(
+                iface.signal_emitter(),
+                <Metadata as zbus::object_server::Interface>::name(),
+                properties,
+                Cow::Borrowed(&[]),
+            )
+            .await
+        {
+            warn!("metadata PropertiesChanged emission failed: {error}");
+        }
+    }
+    Ok(())
+}
+
+#[cfg(test)]
+mod tests {
+    use super::*;
+
+    #[test]
+    fn noise_modes_follow_device_config_bitmask() {
+        let mut snap = Snapshot::idle();
+        apply_controls(
+            &mut snap,
+            &[ControlCommandStatus {
+                identifier: ControlCommandIdentifiers::ListeningModeConfigs,
+                value: vec![0x06],
+            }],
+        );
+
+        assert_eq!(
+            snap.noise_control_modes,
+            vec![MODE_ANC.to_owned(), MODE_TRANSPARENCY.to_owned()]
+        );
+    }
+
+    #[test]
+    fn noise_modes_stay_unknown_without_device_config() {
+        let mut snap = Snapshot::idle();
+        apply_controls(
+            &mut snap,
+            &[ControlCommandStatus {
+                identifier: ControlCommandIdentifiers::ListeningMode,
+                value: vec![0x04],
+            }],
+        );
+
+        assert_eq!(snap.noise_control, MODE_ADAPTIVE);
+        assert!(snap.noise_control_modes.is_empty());
+    }
+}
