+async fn command_worker(commands: Arc<CommandQueue>, session: Arc<Mutex<CommandSession>>) {
+    loop {
+        let notified = commands.ready.notified();
+        let command = commands
+            .pending
+            .lock()
+            .expect("command queue poisoned")
+            .take();
+        let Some(command) = command else {
+            notified.await;
+            continue;
+        };
+        if command.reply.is_closed() {
+            continue;
+        }
+        let result = execute_command(&session, &command).await;
+        let _ = command.reply.send(result);
+    }
