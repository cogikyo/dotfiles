# Secrets manifest — maps encrypted .age files to target paths
# Format: name:target_path:permissions
#
# Sync from machine:  secrets sync
# Decrypt on fresh:   secrets decrypt

# SSH keys
ssh:~/.ssh/id_ed25519:600
ssh_pub:~/.ssh/id_ed25519.pub:644
ssh_work:~/.ssh/id_ed25519_trend:600
ssh_work_pub:~/.ssh/id_ed25519_trend.pub:644
ssh_cogikyo:~/.ssh/cogikyo:600
ssh_cogikyo_pub:~/.ssh/cogikyo.pub:644
ssh_config:~/.ssh/config:600

# API keys
owm_api_key:~/.local/.owm_api_key:600
